{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/app",
      "destination": "/public/app.html"
    },
    {
      "source": "/onboarding",
      "destination": "/public/onboarding.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
